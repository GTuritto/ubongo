# Secrets
.env
.env.*
!.env.example

# SQLite (generated by the app)
*.db
*.db-journal
*.db-wal
*.db-shm

# Generated vault notes (track the directory marker, ignore contents)
vault/*
!vault/.gitkeep

# Self-authored skills: quarantined drafts and pre-overwrite backups are
# generated at runtime (the approval gate materializes approved skills into the
# tracked config/skills/). Not source.
config/skills_candidates/
config/skills_backups/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Test / lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Claude Code / editor state
.specstory/
.history/
.claude/worktrees/
.claude/handoffs/
.claude/settings.local.json
*.code-workspace

# Other AI coding tools' scratch dirs (not used by this project)
.agent/
.codex/
.gemini/
.windsurf/

# Generic tool-synced skills/commands (OpenSpec workflow tooling, skill-browser).
# Not authored for this project. Project-specific skills/commands created
# under .claude/ are NOT covered by these patterns and stay tracked.
.claude/commands/opsx/
.claude/skills/openspec-*/
.claude/skills/skill-browser/
.github/prompts/
.github/skills/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
